# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@db:5432/jp_disclosure

# Redis配置（可选）
REDIS_URL=redis://redis:6379/0

# EDINET API密钥（可选，不提供则使用Demo模式）
# 可在 https://api.edinet-fsa.go.jp/ 申请
EDINET_API_KEY=Demo

# API配置
API_V1_STR=/api/v1
PROJECT_NAME=日本上市公司信息披露平台

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
