# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jp_disclosure

# Redis配置（Windows环境建议禁用）
# 如果需要Redis，取消下面两行的注释
# REDIS_URL=redis://localhost:6379/0
# USE_REDIS=true

# 默认禁用Redis
USE_REDIS=false

# API配置
API_V1_STR=/api/v1
PROJECT_NAME=日本上市公司信息披露平台

# EDINET API配置（可选）
# 申请地址：https://disclosure.edinet-fsa.go.jp/
# EDINET_API_KEY=your_api_key_here

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
